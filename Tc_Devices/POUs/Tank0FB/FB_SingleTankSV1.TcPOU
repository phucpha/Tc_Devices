END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[LimitMaxWeight := lrLimitMaxWeight;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{da8fa2de-5e67-49c5-81d8-18fb7452fe09}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[lrLimitMaxWeight := LimitMaxWeight;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="LimitMinWeight" Id="{b4e7bcc3-3741-428f-a558-a7ec417758e5}">
      <Declaration><![CDATA[PROPERTY LimitMinWeight : LREAL]]></Declaration>
      <Get Name="Get" Id="{9222c5eb-6aac-4765-a7cd-79fa6d0e9eff}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[LimitMinWeight := lrLimitMinWeight;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{4bda1cf5-161a-4b71-8816-a4bdfad8340f}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[lrLimitMinWeight := LimitMinWeight; ]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="MR_Filling" Id="{31dba4ab-4e68-42b2-8699-11e038c277bc}" FolderPath="MR\">
      <Declaration><![CDATA[METHOD MR_Filling : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eState=TANK_IDLE 
	AND bAllowInMaterial
THEN
	eState := TANK_FILLING;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="MR_Reset" Id="{b7fbdb81-7ca2-40fb-8c0f-1c6b095064fc}" FolderPath="MR\">
      <Declaration><![CDATA[METHOD MR_Reset : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bError := FALSE;
bWithDrawDone := FALSE;
MR_Reset := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="MR_Stop" Id="{8e0ae58f-f803-42bb-bfb2-c4909f9c3f1a}" FolderPath="MR\">
      <Declaration><![CDATA[METHOD MR_Stop : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[eState := TANK_STOP;]]></ST>
      </Implementation>
    </Method>
    <Method Name="MR_WithDraw" Id="{f46ebad8-bf4f-4fbd-bf93-7bd1b26757c7}" FolderPath="MR\">
      <Declaration><![CDATA[(*	if withdrawing => still withdraw
	else
		if not stop => MR_Stop before withdraw
*)
METHOD MR_WithDraw : BOOL
VAR_INPUT
	lrWeightWd : LREAL;
	bExecute : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bExecute := bExecute;
IF rTrigExecute.Q
	AND eState=TANK_IDLE 
	AND lrWeight > (lrWeightWd + lrLimitMinWeight) // Check enough weight
	AND bAllowOutMaterial
THEN
	eState := TANK_WITHDRAWING;
	lrWeightWithdraw := lrWeightWd;
	lrWeightBeforeWD := lrWeight;
ELSE
	bWithDrawDone := FALSE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MS_Filling" Id="{bc9ac396-e513-4815-9e54-20b33958e075}" FolderPath="MS\">
      <Declaration><![CDATA[METHOD PROTECTED MS_Filling
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bAllowInMaterial THEN
	iFill.Open();
ELSE
	iFill.Close();
	bError := TRUE;
	eState := TANK_STOP;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="MS_Stop" Id="{7994ec05-7a9b-440c-8343-96d619b74c10}" FolderPath="MS\">
      <Declaration><![CDATA[METHOD PROTECTED MS_Stop
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[poCylinderCoil.Out := FALSE;
iFill.Close();
eState := TANK_IDLE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="MS_Withdraw" Id="{41ff54f8-9253-4da0-92c5-796eae7ab45c}" FolderPath="MS\">
      <Declaration><![CDATA[METHOD PROTECTED MS_Withdraw
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[poCylinderCoil.Out := TRUE;
IF lrWeightWithdrawN > lrWeightWithdraw THEN
	eState := TANK_STOP;
	bWithDrawDone := TRUE;
END_IF
IF NOT bAllowOutMaterial THEN
	bError := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="Ref_iFill" Id="{66f955d5-689a-4852-9b7e-e73d5da1c17f}">
      <Declaration><![CDATA[PROPERTY Ref_iFill : Reference to I_TankFill]]></Declaration>
