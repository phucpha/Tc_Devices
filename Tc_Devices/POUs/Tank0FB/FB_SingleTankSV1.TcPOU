      <Get Name="Get" Id="{19a94231-4e98-4e6c-8bcf-4951ba35c618}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Error ref= bError;]]></ST>
        </Implementation>
      </Get>
    </Property>
