<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_SingleTankSV1" Id="{5ca50686-0462-42c6-af5d-b0dee07be601}" SpecialFunc="None">
    <Declaration><![CDATA[(* Single tank with LimitSwitchLow (piLsLow) and LimitSwitchHigh (piLsHigh)
| using this function when it have INDEPENDENT Measure weight
*)
FUNCTION_BLOCK FB_SingleTankSV1 EXTENDS FB_SingleTankS
VAR
	bAllowInMaterial : BOOL;
	bAllowOutMaterial : BOOL;
	lrLimitMinWeight : LREAL;
	lrLimitMaxWeight : LREAL;
	lrWeightWithdraw : LREAL; 		// weight withdraw Request
	lrWeightBeforeWD : LREAL;
	lrWeightWithdrawN : LREAL;
	lrWeight : LREAL;
	eState : E_TankState;
	iFill : I_TankFill;				// the components that action for fill materials.
	
	rTrigExecute : R_TRIG;
	bExecute : BOOL;//Execute with draw
	bFillError : BOOL;
	bError : BOOL;
	bWithDrawDone : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^();
rTrigExecute(CLK := bExecute);
bAllowOutMaterial := (lrWeight > lrLimitMinWeight);
bAllowInMaterial := (lrWeight < lrLimitMaxWeight);
lrWeightWithdrawN := lrWeight-lrWeightBeforeWD;

CASE eState OF
	TANK_IDLE:
		;// WAIT FOR CMD
	TANK_STOP:
		MS_Stop();
		
	TANK_WITHDRAWING:
		MS_Withdraw();
		
	TANK_FILLING:
		MS_Filling();
END_CASE]]></ST>
    </Implementation>
    <Folder Name="MR" Id="{f1f24279-e1bb-479c-a8c0-d4ef91701c70}" />
    <Folder Name="MS" Id="{4d7427c7-75e0-4a11-b8f5-045af82017e9}" />
    <Property Name="AllowIn" Id="{19454c6c-9627-4b96-a378-44ef75eb1570}">
      <Declaration><![CDATA[PROPERTY AllowIn : Reference to bool]]></Declaration>
      <Get Name="Get" Id="{60617153-04c3-4fc2-9ae7-12ae57dedf08}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AllowIn ref= bAllowInMaterial;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="AllowOut" Id="{39f44b44-a9fa-435a-bb19-391cb7d16478}">
      <Declaration><![CDATA[(*
| Check the minimum condition  (lrWeight > lrLimitMinWeight
								AND piLslow.In;)
*)
PROPERTY AllowOut : REFERENCE TO BOOL ]]></Declaration>
      <Get Name="Get" Id="{b20590ad-c50c-435a-9290-7ae3c5ce7d70}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[AllowOut ref= bAllowOutMaterial;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="AssignIfill" Id="{72d144b2-3662-4d8e-8e09-92841bd0d64b}" FolderPath="MR\">
      <Declaration><![CDATA[METHOD AssignIfill : BOOL
VAR_INPUT
	iFill : I_TankFill;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.iFill := iFill;]]></ST>
      </Implementation>
    </Method>
